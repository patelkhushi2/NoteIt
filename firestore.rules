rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function validSharedRecipients(data) {
      return !('sharedWith' in data)
        || (data.sharedWith is list && data.sharedWith.size() <= 25);
    }

    match /notes/{noteId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && validSharedRecipients(request.resource.data);
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
          || (request.auth.token.email_verified == true
            && resource.data.sharedWith is list
            && request.auth.token.email in resource.data.sharedWith));
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && validSharedRecipients(request.resource.data);
    }

    match /folders/{folderId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    match /supportMessages/{messageId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
